{
  "env": {
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_BUG_COMMAND": "1"
  },
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(grep:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(gh pr checks:*)",
      "Bash(cf api:*)",
      "Bash(cf auth:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "alwaysThinkingEnabled": false,
  "defaultMode": "plan",
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true
  },
  "gitAttribution": false,
  "includeCoAuthoredBy": false,
  "keybindings": {
    "sendToBackground": "cmd+b cmd+b"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Zug zug",
      "Work work",
      "Something need doing",
      "Ready to work",
      "Me busy, leave me alone",
      "Yes, me lord",
      "What you want",
      "Job's done soon",
      "Off I go then",
      "Dabu",
      "Lok'tar ogar",
      "For the Horde",
      "More work",
      "Me not that kind of orc",
      "Swobu"
    ]
  }
}
