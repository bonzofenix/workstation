{
  "env": {
    "DISABLE_BUG_COMMAND": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "ENABLE_TOOL_SEARCH": "false"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "Bash(grep:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(gh pr checks:*)",
      "Bash(cf api:*)",
      "Bash(cf auth:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh pr create*)",
      "Bash(gh pr list*)",
      "Bash",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(pwd)",
      "Bash(git status)",
      "Bash(python3:*)",
      "Bash(pip *)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "MultiEdit(*)",
      "Grep",
      "Glob"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(*sudo*)"
    ]
  },
  "model": "sonnet[1m]",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/peon-ping/peon.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "atlassian@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "sandbox": {
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "*.githubusercontent.com",
        "pypi.org",
        "files.pythonhosted.org",
        "npmjs.org",
        "registry.npmjs.org",
        "raw.githubusercontent.com"
      ]
    }
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Zug zug",
      "Work work",
      "Something need doing",
      "Ready to work",
      "Me busy, leave me alone",
      "Yes, me lord",
      "What you want",
      "Job's done soon",
      "Off I go then",
      "Dabu",
      "Lok'tar ogar",
      "For the Horde",
      "More work",
      "Me not that kind of orc",
      "Swobu"
    ]
  },
  "alwaysThinkingEnabled": false,
  "defaultMode": "plan",
  "gitAttribution": false,
  "keybindings": {
    "sendToBackground": "ctrl+g ctrl+g"
  }
}
