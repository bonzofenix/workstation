#!/usr/bin/env bash

set -euo pipefail

# --- Constants (Replace Magic Number with Symbolic Constant) ---

readonly STATUS_SUCCESS="success"
readonly STATUS_FAILURE="failure"
readonly STATUS_PENDING="pending"
readonly STATUS_SKIPPED="skipped"

readonly BUCKET_PASS="pass"
readonly BUCKET_FAIL="fail"
readonly BUCKET_PENDING="pending"
readonly BUCKET_SKIP="skip"
readonly BUCKET_NEUTRAL="neutral"

readonly STATE_SUCCESS="SUCCESS"
readonly STATE_COMPLETED="COMPLETED"
readonly STATE_FAILURE="FAILURE"
readonly STATE_TIMED_OUT="TIMED_OUT"
readonly STATE_ACTION_REQUIRED="ACTION_REQUIRED"
readonly STATE_SKIPPED="SKIPPED"
readonly STATE_NEUTRAL="NEUTRAL"
readonly STATE_IN_PROGRESS="IN_PROGRESS"
readonly STATE_QUEUED="QUEUED"
readonly STATE_REQUESTED="REQUESTED"
readonly STATE_WAITING="WAITING"

readonly COLOR_RED="red"
readonly COLOR_GREEN="green"
readonly COLOR_YELLOW="yellow"

readonly EMOJI_SUCCESS="✓"
readonly EMOJI_FAILURE="✗"
readonly EMOJI_PENDING="⋯"
readonly EMOJI_SKIPPED="○"
readonly EMOJI_WARNING="⚠"

readonly ZERO=0

# --- Value Objects (Introduce Parameter Object) ---

declare -A CHECK_STATS

function init_check_stats() {
    CHECK_STATS[total]=0
    CHECK_STATS[success]=0
    CHECK_STATS[failure]=0
    CHECK_STATS[pending]=0
    CHECK_STATS[skipped]=0
}

function increment_stat() {
    local key="${1}"
    ((CHECK_STATS[${key}]++))
}

# --- Query Functions ---

function pr_number_is_set() {
    [[ -n "${PR_NUMBER:-}" ]]
}

function repository_is_github() {
    gh repo view &> /dev/null
}

function has_failures() {
    [[ "${CHECK_STATS[failure]}" -gt "${ZERO}" ]]
}

function has_pending() {
    [[ "${CHECK_STATS[pending]}" -gt "${ZERO}" ]]
}

function has_no_checks() {
    local checks_json="${1}"
    [[ $(echo "${checks_json}" | jq 'length') -eq "${ZERO}" ]]
}

# --- Status Determination (Replace Conditional with Polymorphism pattern, adapted for bash) ---

function classify_by_bucket() {
    local bucket="${1}"

    case "${bucket}" in
        "${BUCKET_PASS}") echo "${STATUS_SUCCESS}" ;;
        "${BUCKET_FAIL}") echo "${STATUS_FAILURE}" ;;
        "${BUCKET_PENDING}") echo "${STATUS_PENDING}" ;;
        "${BUCKET_SKIP}"|"${BUCKET_NEUTRAL}") echo "${STATUS_SKIPPED}" ;;
        *) echo "" ;;
    esac
}

function classify_by_state() {
    local state="${1}"

    case "${state}" in
        "${STATE_SUCCESS}"|"${STATE_COMPLETED}")
            echo "${STATUS_SUCCESS}" ;;
        "${STATE_FAILURE}"|"${STATE_TIMED_OUT}"|"${STATE_ACTION_REQUIRED}")
            echo "${STATUS_FAILURE}" ;;
        "${STATE_SKIPPED}"|"${STATE_NEUTRAL}")
            echo "${STATUS_SKIPPED}" ;;
        "${STATE_IN_PROGRESS}"|"${STATE_QUEUED}"|"${STATE_REQUESTED}"|"${STATE_WAITING}")
            echo "${STATUS_PENDING}" ;;
        *)
            echo "${STATUS_PENDING}" ;;
    esac
}

function classify_check_status() {
    local bucket="${1}"
    local state="${2}"

    local classification
    classification=$(classify_by_bucket "${bucket}")

    if [[ -n "${classification}" ]]; then
        echo "${classification}"
    else
        classify_by_state "${state}"
    fi
}

# --- Data Access Functions ---

function get_pr_checks() {
    local pr_number="${1}"
    gh pr checks "${pr_number}" --json name,state,bucket,completedAt
}

function extract_check_field() {
    local check="${1}"
    local field="${2}"
    echo "${check}" | jq -r ".${field}"
}

# --- Business Logic Functions ---

function count_check_by_classification() {
    local classification="${1}"

    case "${classification}" in
        "${STATUS_SUCCESS}") increment_stat "success" ;;
        "${STATUS_FAILURE}") increment_stat "failure" ;;
        "${STATUS_PENDING}") increment_stat "pending" ;;
        "${STATUS_SKIPPED}") increment_stat "skipped" ;;
    esac
}

function aggregate_check_stats() {
    local checks_json="${1}"

    init_check_stats
    CHECK_STATS[total]=$(echo "${checks_json}" | jq 'length')

    while IFS= read -r check; do
        local state bucket classification

        state=$(extract_check_field "${check}" "state")
        bucket=$(extract_check_field "${check}" "bucket")
        classification=$(classify_check_status "${bucket}" "${state}")

        count_check_by_classification "${classification}"
    done < <(echo "${checks_json}" | jq -c '.[]')
}

# --- Presentation Functions ---

function determine_overall_status() {
    if has_failures; then
        echo "${COLOR_RED}" "${EMOJI_FAILURE}" "${CHECK_STATS[failure]} check(s) failed"
    elif has_pending; then
        echo "${COLOR_YELLOW}" "${EMOJI_PENDING}" "${CHECK_STATS[pending]} check(s) in progress"
    else
        echo "${COLOR_GREEN}" "${EMOJI_SUCCESS}" "All checks passed"
    fi
}

function print_header() {
    local pr_number="${1}"
    gum style \
        --border double \
        --border-foreground 212 \
        --padding "1 2" \
        --margin "1 0" \
        "CI Status for PR #${pr_number}"
}

function print_status_line() {
    local color="${1}"
    local emoji="${2}"
    local text="${3}"

    gum style \
        --foreground "${color}" \
        --bold \
        "${emoji} ${text}"
}

function print_stats_line() {
    gum style \
        --margin "0 2" \
        "Total: ${CHECK_STATS[total]}  |  ${EMOJI_SUCCESS} Success: ${CHECK_STATS[success]}  |  ${EMOJI_FAILURE} Failed: ${CHECK_STATS[failure]}  |  ${EMOJI_PENDING} Pending: ${CHECK_STATS[pending]}  |  ${EMOJI_SKIPPED} Skipped: ${CHECK_STATS[skipped]}"
}

function print_summary() {
    local status_parts
    read -r -a status_parts < <(determine_overall_status)

    print_status_line "${status_parts[0]}" "${status_parts[1]}" "${status_parts[2]} ${status_parts[3]}"
    echo ""
    print_stats_line
}

function print_error() {
    local message="${1}"
    gum style \
        --foreground "${COLOR_RED}" \
        --bold \
        "ERROR: ${message}" >&2
}

function print_usage_hint() {
    local hint="${1}"
    echo "" >&2
    gum style --margin "0 2" "${hint}" >&2
}

function print_no_checks_warning() {
    local pr_number="${1}"
    gum style \
        --foreground "${COLOR_YELLOW}" \
        --margin "1 2" \
        "${EMOJI_WARNING} No checks found for PR #${pr_number}"
}

# --- Validation Functions (Extract Method) ---

function validate_pr_number() {
    if pr_number_is_set; then
        return 0
    fi

    print_error "PR_NUMBER environment variable is not set"
    print_usage_hint "Usage: PR_NUMBER=123 analyze-ci"
    return 1
}

function validate_github_cli() {
    if command -v gh &> /dev/null; then
        return 0
    fi

    print_error "GitHub CLI (gh) is not installed"
    print_usage_hint "Install with: brew install gh"
    return 1
}

function validate_github_repository() {
    if repository_is_github; then
        return 0
    fi

    print_error "Not in a GitHub repository or not authenticated"
    print_usage_hint "Run: gh auth login"
    return 1
}

function validate_environment() {
    validate_pr_number || return 1
    validate_github_cli || return 1
    validate_github_repository || return 1
}

# --- Orchestration Functions ---

function fetch_and_display_checks() {
    local pr_number="${1}"
    local checks_json

    if ! checks_json=$(get_pr_checks "${pr_number}" 2>&1); then
        print_error "Failed to fetch checks for PR #${pr_number}"
        print_usage_hint "${checks_json}"
        return 1
    fi

    if has_no_checks "${checks_json}"; then
        print_no_checks_warning "${pr_number}"
        return 0
    fi

    aggregate_check_stats "${checks_json}"
    print_summary
    echo ""
}

function analyze_pr_checks() {
    local pr_number="${PR_NUMBER}"

    print_header "${pr_number}"
    fetch_and_display_checks "${pr_number}"
}

# --- Main Entry Point ---

function main() {
    validate_environment || exit 1
    analyze_pr_checks || exit 1
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
