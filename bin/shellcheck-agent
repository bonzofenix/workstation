#!/usr/bin/env bash
# Wrapper script for ShellCheck Agent

# Get the directory where this script lives
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
AGENT_PATH="$SCRIPT_DIR/../lib/agents/shellcheck/shellcheck_agent.py"

# Check if the agent exists
if [ ! -f "$AGENT_PATH" ]; then
    echo "Error: ShellCheck agent not found at $AGENT_PATH"
    exit 1
fi

# Execute the agent
exec python3 "$AGENT_PATH" "$@"
