#!/bin/bash

set -eu

function start_cf-hcp-oci() {
  local -r tag="${1:-master}"

  if [[ -z "${PRODUCT_DOCKER_REGISTRY:-}" ]]; then
    echo "Error: PRODUCT_DOCKER_REGISTRY environment variable not set"
    echo "Please set it in your ~/.bash_profile or ~/.zshrc"
    exit 1
  fi

  local -r image="${PRODUCT_DOCKER_REGISTRY}/product-cf-hcp:${tag}"

  echo "Using image: ${image}"

  # Check if image exists locally
  if docker image inspect "${image}" &> /dev/null
  then
    echo 'Image already exists locally.'
    echo -n 'Do you want to pull the latest version? [y/N]: '
    read -r answer
    case "${answer}" in
      [Yy]|[Yy][Ee][Ss])
        echo 'Pulling latest image...'
        docker pull "${image}"
        ;;
      *)
        echo 'Using existing local image.'
        ;;
    esac
  else
    echo 'Image not found locally. Pulling...'
    docker pull "${image}"
  fi

  echo "Starting product with image: ${image}"

  # Extract startup script to a temporary file to avoid process substitution issues
  local startup_script=$(mktemp)
  trap "rm -f ${startup_script}" EXIT

  docker run --rm "${image}" /usr/bin/env startup 2>/dev/null > "${startup_script}"
  chmod +x "${startup_script}"
  python3 "${startup_script}" --image="${image}" "${@:2}"
}

echo 'ℹ️ Use `start_cf-hcp-oci <tag> [args…]` to start product with interactive image update prompt. Default tag: master' 1>&2
echo 'ℹ️ Use `start-product [version]` to start product. If no version provided, reads from product.yml' 1>&2

if [ $# -gt 0 ]; then
  # Use the provided version parameter
  start_cf-hcp-oci "$1" "${@:2}"
else
  # Default behavior: read version from product.yml
  product_version=$(cat product.yml | yq .product.version)
  start_cf-hcp-oci "develop-${product_version}"
fi
