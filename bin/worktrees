#!/bin/bash
set -eu

command -v gum >/dev/null 2>&1 || { echo "Error: gum not installed. Install with: brew install gum" >&2; exit 1; }

# Fetch PR info for all branches in one call
pr_json=$(gh pr list --author=@me --json number,headRefName,url --limit 100 2>/dev/null || echo "[]")
reviewer_json=$(gh pr list --reviewer=@me --json number,headRefName,url --limit 100 2>/dev/null || echo "[]")
pr_json=$(echo "$pr_json" "$reviewer_json" | jq -s 'add | unique_by(.number)')

worktree_list=""
while IFS= read -r line; do
  if [[ "$line" == worktree* ]]; then
    path="${line#worktree }"
  elif [[ "$line" == branch* ]]; then
    branch="${line#branch refs/heads/}"
    pr_url=$(echo "$pr_json" | jq -r ".[] | select(.headRefName == \"$branch\") | .url" 2>/dev/null || echo "")
    if [[ -n "$pr_url" ]]; then
      worktree_list+="$branch $pr_url"$'\n'
    else
      worktree_list+="$branch"$'\n'
    fi
  elif [[ "$line" == "detached" ]]; then
    worktree_list+="HEAD detached"$'\n'
  fi
done < <(git worktree list --porcelain)

# Strip trailing newline
worktree_list="${worktree_list%$'\n'}"

selected=$(echo "$worktree_list" | gum choose)

# Extract branch name (first word) and find matching worktree path
branch_name=$(echo "$selected" | awk '{print $1}')

selected_path=$(git worktree list --porcelain | awk -v branch="refs/heads/$branch_name" '
  /^worktree / { path = $2 }
  /^branch / { if ($2 == branch) print path }
')

if [[ -z "$selected_path" ]]; then
  # fallback: main worktree
  selected_path=$(git worktree list --porcelain | awk '/^worktree / { print $2; exit }')
fi

cd "$selected_path"
exec "$SHELL"
