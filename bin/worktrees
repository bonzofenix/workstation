#!/bin/bash
set -eu

# Check for required dependencies
command -v gum >/dev/null 2>&1 || { echo "Error: gum not installed. Install with: brew install gum" >&2; exit 1; }

# Get list of worktrees and format them nicely
# Format: branch name (path)
worktree_list=$(git worktree list --porcelain | awk '
  /^worktree / { path = $2 }
  /^branch / {
    branch = $2
    gsub("refs/heads/", "", branch)
    print branch " (" path ")"
  }
  /^detached$/ {
    print "HEAD detached (" path ")"
  }
')

# Let user select a worktree
selected=$(echo "$worktree_list" | gum choose)

# Extract the path from the selection
selected_path=$(echo "$selected" | sed 's/.*(\(.*\)).*/\1/')

# Change to the selected worktree
cd "$selected_path"

# Start a new shell in the worktree directory
exec "$SHELL"
