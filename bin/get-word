#!/bin/zsh

WORDLIST_URL="https://raw.githubusercontent.com/bitcoin/bips/master/bip-0039/english.txt"
WORDLIST_FILE="bip39_words.txt"

# Ensure gum is installed
if ! command -v gum &>/dev/null; then
    echo "gum is not installed. Install with: brew install gum"
    exit 1
fi

# Download wordlist if not exists
if [[ ! -f "$WORDLIST_FILE" ]]; then
    curl -sSL "$WORDLIST_URL" -o "$WORDLIST_FILE"
fi

get_word() {
    local number="$1"
    awk "NR==$number" "$WORDLIST_FILE"
}

while true; do
    number=$(gum input --placeholder "Enter a number (1-2048) or 'q' to quit")
    [[ "$number" == "q" ]] && break
    [[ "$number" =~ ^[0-9]+$ ]] || { gum style --foreground 1 "Invalid input"; continue; }
    ((number >= 1 && number <= 2048)) || { gum style --foreground 1 "Out of range"; continue; }
    word=$(get_word "$number")
    gum style --bold --foreground 2 "Word $number: $word"
done

