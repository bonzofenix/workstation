#!/usr/bin/env bash
set -euo pipefail

# Check if in git repo
if ! git rev-parse --git-dir >/dev/null 2>&1; then
  gum style --foreground 196 "Error: Not in a git repository"
  exit 1
fi

# Parse flags
ALL=false
if [[ "${1:-}" == "--all" ]]; then
  ALL=true
fi

gum spin --spinner dot --title "Fetching remotes..." -- git fetch --all --prune 2>&1 || gum style --foreground 214 "Warning: Some remotes failed to fetch"

# Parse worktree list once — emit "live" or "prunable" entries
worktree_raw=$(git worktree list --porcelain)

# Live worktrees: have a branch and a real directory (skip main worktree)
worktrees_info=$(awk '
  /^worktree / { path = $2; is_first = (NR == 1) }
  /^branch /   { branch = $2; gsub("refs/heads/", "", branch) }
  /^$/          { if (!is_first && branch != "") print branch "|" path; branch = "" }
' <<< "$worktree_raw")

# Prunable worktrees: directory already gone
prunable_info=$(awk '
  /^worktree / { path = $2 }
  /^branch /   { branch = $2; gsub("refs/heads/", "", branch) }
  /^prunable / { print branch "|" path; branch = "" }
' <<< "$worktree_raw")

# Handle prunable worktrees upfront — directory is already gone, just clean registrations
if [[ -n "$prunable_info" ]]; then
  gum style --bold --foreground 214 "Prunable worktrees (directory already deleted):"
  while IFS='|' read -r branch path; do
    gum style --foreground 248 "  ${branch} (${path})"
  done <<< "$prunable_info"
  echo
  git worktree prune
  if gum confirm "Delete associated branches for prunable worktrees?"; then
    while IFS='|' read -r branch path; do
      if [[ -n "$branch" ]]; then
        if git branch -D "$branch" 2>/dev/null; then
          gum style --foreground 82 "  Deleted branch: ${branch}"
        fi
      fi
    done <<< "$prunable_info"
  fi
  echo
fi

if [[ -z "$worktrees_info" ]]; then
  gum style --foreground 240 "No worktrees found (excluding main worktree)."
  exit 0
fi

if [[ "$ALL" == true ]]; then
  worktrees_to_remove=""
  while IFS='|' read -r branch path; do
    worktrees_to_remove+="${branch} (${path})"$'\n'
  done <<< "$worktrees_info"

  branches_to_cleanup=$(echo "$worktrees_info" | cut -d'|' -f1)
else
  # Find branches that are merged
  merged_branches=$(git branch --merged origin/HEAD | grep -vE '^\*|main$|master$|develop$' | awk '{print $2}' || true)

  # Find branches where upstream is gone
  gone_branches=$(git branch -vv | grep ': gone]' | grep -vE '^\*|main$|master$|develop$' | awk '{print $2}' || true)

  # Combine both lists and remove duplicates
  branches_to_cleanup=$(echo -e "$merged_branches\n$gone_branches" | sort -u | grep -v '^$' || true)

  if [[ -z "$branches_to_cleanup" ]]; then
    gum style --foreground 240 "No merged or gone branches found. No worktrees to clean up."
    exit 0
  fi

  # Filter worktrees whose branches are in the cleanup list
  worktrees_to_remove=""
  while IFS='|' read -r branch path; do
    if echo "$branches_to_cleanup" | grep -q "^${branch}$"; then
      worktrees_to_remove+="${branch} (${path})"$'\n'
    fi
  done <<< "$worktrees_info"
fi

if [[ -z "$worktrees_to_remove" ]]; then
  gum style --foreground 240 "No worktrees associated with merged or gone branches."
  exit 0
fi

gum style --bold --foreground 212 "Worktrees to delete:"
echo "$worktrees_to_remove" | gum style --foreground 248
echo

gum confirm "Delete these worktrees?" || exit 1

# Remove each worktree
while IFS='|' read -r branch path; do
  if echo "$branches_to_cleanup" | grep -q "^${branch}$"; then
    gum spin --spinner dot --title "Removing $branch..." -- git worktree remove "$path" 2>/dev/null || git worktree remove -f "$path"
  fi
done <<< "$worktrees_info"

echo
if gum confirm "Also delete the associated branches?"; then
  # Delete the branches
  while IFS='|' read -r branch path; do
    if echo "$branches_to_cleanup" | grep -q "^${branch}$"; then
      git branch -D "$branch" 2>/dev/null || true
    fi
  done <<< "$worktrees_info"
  gum style --foreground 82 "✓ Deleted worktrees and branches"
else
  gum style --foreground 82 "✓ Deleted worktrees (branches preserved)"
fi

git worktree prune
