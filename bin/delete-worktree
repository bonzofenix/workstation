#!/bin/bash
set -eu

# Get list of worktrees excluding the main worktree
# Format: branch name (path)
worktree_list=$(git worktree list --porcelain | awk '
  BEGIN { skip_first = 1 }
  /^worktree / {
    path = $2
    if (skip_first) {
      skip_first = 0
      next
    }
  }
  /^branch / {
    branch = $2
    gsub("refs/heads/", "", branch)
    print branch " (" path ")"
  }
  /^detached$/ {
    print "HEAD detached (" path ")"
  }
')

# Check if there are any worktrees to delete
if [ -z "$worktree_list" ]; then
  echo "No worktrees to delete (main worktree cannot be deleted)"
  exit 0
fi

# Let user select a worktree to delete
selected=$(echo "$worktree_list" | gum choose --header "Select a worktree to delete:")

# Extract the path from the selection
selected_path=$(echo "$selected" | sed 's/.*(\(.*\)).*/\1/')

# Extract the branch name from the selection
selected_branch=$(echo "$selected" | sed 's/ (.*//')

# Confirm deletion
if gum confirm "Delete worktree at $selected_path and remove branch $selected_branch?"; then
  # Remove the worktree
  git worktree remove "$selected_path"

  # Ask if user wants to delete the branch as well
  if gum confirm "Also delete the branch $selected_branch?"; then
    git branch -D "$selected_branch"
    echo "Worktree and branch deleted successfully"
  else
    echo "Worktree deleted, branch preserved"
  fi
else
  echo "Deletion cancelled"
fi
