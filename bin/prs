#!/bin/zsh

set -eu

ALL=0
RAW=0
while getopts "awr" opt; do
  case $opt in
    a) ALL=1 ;;
    r) RAW=1 ;;
  esac
done

GH_OPTS=(--state=open --json number,repository,title)
cd "$OLDPWD"
repo_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")

if [[ -z "$repo_root" ]]; then
  echo "Not inside a git repo"
  exit 1
fi

cd "$repo_root"

remote_url=$(git config --get remote.origin.url || echo "")
if [[ -z "$remote_url" ]]; then
  echo "Could not get remote.origin.url"
  exit 1
fi

github_hostname=$(echo "$remote_url" | sed -E 's#(git@|https://)([^/:]+).*#\2#')
echo "Fetching PRs for $github_hostname"

export GH_HOST="$github_hostname"

if [[ "$ALL" -eq 0 ]]; then
    GH_OPTS=(--author=@me "${GH_OPTS[@]}")
fi

choices=()
while IFS= read -r pr; do
  number=$(jq -r '.number' <<<"$pr")
  repo=$(jq -r '.repository.nameWithOwner' <<<"$pr")
  title=$(jq -r '.title' <<<"$pr")

  # Fetch review decision separately
  review_decision=$(gh pr view "$number" -R "$repo" --json reviewDecision 2>/dev/null | jq -r '.reviewDecision // "NONE"')

  checks=$(gh pr checks "$number" -R "$repo" --json state 2>/dev/null | jq -r '.[].state // "UNKNOWN"')
  green=$(grep -c "SUCCESS" <<<"$checks" || true)
  red=$(grep -c "FAILURE" <<<"$checks" || true)
  running=$(grep -c "IN_PROGRESS" <<<"$checks" || true)

  # Set approval status icon
  case "$review_decision" in
    APPROVED) approval="✓" ;;
    CHANGES_REQUESTED) approval="✗" ;;
    REVIEW_REQUIRED) approval="?" ;;
    *) approval="-" ;;
  esac

  # Pad the PR number to 6 characters for alignment
  padded_number=$(printf "%-6s" "$number")
  choices+=("${padded_number}${repo} - [${approval}] [✅$green ❌$red ⏳$running] ${title}")

  if [[ "$RAW" -eq 1 ]]; then
    echo "PR #${number}: ${title}"
    echo "Repository: ${repo}"
    echo "Link: https://${github_hostname}/${repo}/pull/${number}"
    echo ""
  fi
done < <(gh search prs "${GH_OPTS[@]}" | jq -c '.[]')

if [[ ${#choices[@]} -eq 0 ]]; then
  echo "No open PRs found"
  exit 0
fi

if [[ "$RAW" -eq 1 ]]; then
  exit 0
fi

selected_pr=$(printf "%s\n" "${choices[@]}" | gum choose)
[[ -z "$selected_pr" ]] && exit 1

pr_number=$(echo "$selected_pr" | awk '{print $1}')
repo_name=$(echo "$selected_pr" | sed -E 's/^[0-9]+ +([^ ]+) -.*/\1/')

echo "$github_hostname/$repo_name"
gh pr view -w "$pr_number" -R "$repo_name"

